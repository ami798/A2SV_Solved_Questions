#include <stdlib.h>

int* findUnion(int* a, int n, int* b, int m, int* returnSize) {
    
   
    int freq[100001] = {0};
    
    
    for(int i = 0; i < n; i++) {
        freq[a[i]] = 1;
    }
    
    
    for(int i = 0; i < m; i++) {
        freq[b[i]] = 1;
    }
    
   
    int count = 0;
    for(int i = 0; i <= 100000; i++) {
        if(freq[i] == 1)
            count++;
    }
    
    
    int* result = (int*)malloc(count * sizeof(int));
    
    
    int index = 0;
    for(int i = 0; i <= 100000; i++) {
        if(freq[i] == 1) {
            result[index++] = i;
        }
    }
    
    *returnSize = count;
    return result;
}